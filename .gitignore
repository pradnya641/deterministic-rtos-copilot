# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this can be useful so everyone uses the same version.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different python versions, they may encounter issues.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is authorative and should be tracked
#poetry.lock

# pdm
#   Similar to Poetry and Pipenv, pdm.lock is authorative and should be tracked
#pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/

